# GitHub Pages production builds keep local media disabled and use GitHub
# Releases URLs when VITE_GITHUB_OWNER is available.
VITE_ENABLE_LOCAL_MEDIA=false

# GitHub Releases media URL configuration.
VITE_GITHUB_OWNER=
VITE_GITHUB_REPOSITORY_NAME=jiangrui-ai-flight-lab
VITE_GITHUB_MEDIA_TAG=media-current

# Tencent COS + CDN media distribution. Leave empty to fall back to
# GitHub Releases in production and local media in development.
VITE_MEDIA_CDN_BASE_URL=

# PowerShell upload script environment variables, not exposed to Vite.
# TENCENT_SECRET_ID=
# TENCENT_SECRET_KEY=
# TENCENT_COS_BUCKET=
# TENCENT_COS_REGION=ap-guangzhou
